# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Google Gemini API Key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Gemini model name (по умолчанию gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://tripmaster:tripmaster@db:5432/tripmaster

# Публичный URL для Telegram Mini App (с HTTPS)
WEBAPP_URL=https://pachanland.ru

# Хост и порт для FastAPI сервера
HOST=0.0.0.0
PORT=8000
